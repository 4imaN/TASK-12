# ─────────────────────────────────────────────
# RailOps Offline Schedule & Inventory Control
# Run `npm run bootstrap` to create .env with generated secrets and TLS certs.
# Or copy this file to .env and adjust values manually.
# ─────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=change-me-in-production
MYSQL_DATABASE=railops

# Backend DB connection
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me-in-production
DB_NAME=railops

# TLS certificates
# Canonical host location: backend/certs/ (generated by scripts/generate-certs.sh)
# Docker containers mount backend/certs/ → /app/certs/ (see docker-compose.yml)
# For local dev, override with: export TLS_CERT_PATH=./certs/server.crt (from backend/)
TLS_CERT_PATH=/app/certs/server.crt
TLS_KEY_PATH=/app/certs/server.key

# Security mode: 'strict' (requires TLS, default) or 'test' (allows HTTP, only when NODE_ENV=test).
# TLS is mandatory in all operational modes. HTTP is permitted only for isolated test runs.
# SECURITY_MODE=strict

# CORS (comma-separated list of allowed origins)
# The frontend dev server runs HTTPS on port 8443 (using generated TLS certs).
CORS_ORIGINS=https://localhost:8443

# Phone encryption key (minimum 16 characters, ideally 32 for AES-256)
# Generated by bootstrap.sh — do NOT commit actual secrets
PHONE_ENCRYPTION_KEY=change-this-to-a-32-char-secret!

# Backup
BACKUP_PATH=/backups
# Comma-separated absolute paths that backup_path must be within (path escape prevention)
BACKUP_ALLOWED_ROOTS=/backups,/tmp/railops-backups
